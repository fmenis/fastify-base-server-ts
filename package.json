{
  "name": "fastify-base-server-ts",
  "version": "0.0.1",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --inspect -r dotenv/config dist/index.js",
    "dev": "nodemon --config nodemon.json --inspect -r dotenv/config src/index.ts",
    "initStack": "cd ./trips-stack && docker compose up -d",
    "shutdownStack": "cd ./trips-stack && docker compose down -d",
    "rebuildDb": "./trips-stack/rebuild-db.sh",
    "applyMigrations": "npx prisma db push --skip-generate",
    "test:e2e": "tap --ts --jobs=1 test/**/*.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/env": "^4.3.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/sensible": "^5.5.0",
    "@fastify/swagger": "^8.12.2",
    "@fastify/swagger-ui": "^2.0.1",
    "@prisma/client": "^5.7.1",
    "@sinclair/typebox": "^0.32.3",
    "axios": "^1.6.3",
    "close-with-grace": "^1.2.0",
    "fastify": "^4.25.2",
    "prisma": "^5.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "@types/node": "^20.10.5",
    "@types/tap": "^15.0.11",
    "fastify-tsconfig": "^2.0.0",
    "nodemon": "^3.0.2",
    "tap": "^16.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
